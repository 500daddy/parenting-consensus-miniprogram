<view class="page with-tab result-page">
  <view class="result-search card">
    <view class="search-icon"></view>
    <view class="result-keyword">{{keyword || '搜索育儿问题'}}</view>
    <view class="change-btn" bindtap="goSearch">换一个</view>
  </view>

  <view wx:if="{{noResult}}" class="empty-card card">
    <view class="empty-icon">问</view>
    <view class="empty-copy">
      <view class="empty-title">暂时没有找到精确共识</view>
      <view class="empty-desc">可以换一种问法，或者先查看首页和问答页里已经整理好的热门问题。</view>
    </view>
    <button class="btn-plain primary-button" bindtap="goSearch">重新搜索</button>
  </view>

  <view wx:if="{{noResult && fallbackQuestions.length}}" class="section">
    <view class="section-head">
      <view class="section-title">先看看这些问题</view>
    </view>
    <view class="related-grid">
      <view wx:for="{{fallbackQuestions}}" wx:key="id" class="tap-card related-card card" bindtap="goQuestion" data-id="{{item.id}}">
        <view class="related-title">{{item.shortTitle}}</view>
        <view class="related-sub">{{item.summary}}</view>
        <view class="related-arrow">›</view>
      </view>
    </view>
  </view>

  <block wx:if="{{result}}">
    <view class="current-question-card card">
      <view class="current-question-label">当前问题</view>
      <view class="current-question-title">{{result.question.title}}</view>
      <view class="current-question-meta">
        <text>{{result.question.categoryName}}</text>
        <text>{{result.question.scene}}</text>
        <text>{{result.question.riskLevel}}风险</text>
      </view>
    </view>

    <view class="summary-card card">
      <view class="summary-head">
        <view class="summary-title-wrap">
          <image class="badge pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" />
          <view class="summary-title">先给结论</view>
        </view>
        <view class="summary-actions">
          <button class="btn-plain summary-action-btn share-action-btn" open-type="share" aria-label="分享当前问题">
            <view class="summary-action-icon share-action-icon">
              <view class="share-arrow-head"></view>
            </view>
            <text>分享</text>
          </button>
          <button class="btn-plain summary-action-btn favorite-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite" aria-label="{{isFavorite ? '取消收藏' : '收藏'}}">
            <image class="summary-action-icon favorite-icon pixel-img" src="{{isFavorite ? actionIconPaths.star : actionIconPaths.favorite}}" mode="aspectFit" />
            <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
          </button>
        </view>
      </view>
      <view class="conclusion-box">
        <view class="check-dot">✓</view>
        <view class="conclusion-main">
          <view class="conclusion-label">本地样例答案</view>
          <view class="conclusion-text">{{result.displayConclusion}}</view>
        </view>
      </view>
      <view wx:if="{{result.riskNotice}}" class="risk-notice card">
        <image class="risk-icon pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" />
        <view class="risk-copy">
          <view class="risk-title">{{result.isHighRisk || result.riskLevel === '高' ? '优先看风险' : '健康提醒'}}</view>
          <view class="risk-text">{{result.riskNotice}}</view>
        </view>
      </view>
      <view class="summary-meta">{{result.dataSourceNote}}</view>

      <view class="viewpoint-title">不同观点在说什么</view>
      <view class="viewpoint-list">
        <view wx:for="{{result.viewpoints}}" wx:key="id" class="viewpoint-card card">
          <view class="viewpoint-head">
            <view class="viewpoint-name">
              <view class="dot" style="background: {{item.color}};"></view>
              <text>{{item.displayTitle}}</text>
            </view>
            <view class="viewpoint-percent" style="color: {{item.color}};">{{item.percentage}}%</view>
          </view>
          <view class="viewpoint-text">{{item.summary}}</view>
          <view class="viewpoint-track">
            <view class="viewpoint-fill" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title"><image class="question-mark pixel-img" src="{{actionIconPaths.question}}" mode="aspectFit" /><text>为什么这么认为</text></view>
      <view class="reason-grid">
        <view wx:for="{{result.reasons}}" wx:key="id" class="reason-card tone-{{item.tone}}">
          <image class="reason-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
          <view class="reason-title">{{item.title}}</view>
          <view class="reason-desc">{{item.description}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title"><image class="shield-small pixel-img" src="{{actionIconPaths.authority}}" mode="aspectFit" /><text>权威内容推荐</text></view>
        <button class="btn-plain section-more" bindtap="goAuthority">更多内容 ›</button>
      </view>
      <view wx:if="{{result.authorityView}}" class="authority-view card">
        <view class="authority-view-label">权威观点</view>
        <view class="authority-view-text">{{result.authorityView}}</view>
      </view>
      <view class="authority-list">
        <view wx:for="{{result.authoritySources}}" wx:key="id" class="tap-card authority-row card" bindtap="goAuthority" data-type="{{item.type}}">
          <image class="authority-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
          <view class="authority-main">
            <view class="authority-head">
              <view class="authority-title">{{item.typeName}}</view>
              <text class="trust-dot">{{item.trustLabel}}</text>
            </view>
            <view class="authority-summary">{{item.summary}}</view>
            <view class="authority-tags">
              <text wx:for="{{item.tags}}" wx:key="*this" class="authority-tag">{{item}}</text>
            </view>
          </view>
          <view class="row-arrow"></view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title"><image class="warn-mark pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" /><text>安全提醒</text></view>
      <view wx:if="{{result.safetyNotice}}" class="safety-notice card">{{result.safetyNotice}}</view>
      <view class="warning-grid">
        <view wx:for="{{result.warnings}}" wx:key="*this" class="warning-tile warning-{{index}}">
          <view class="warning-icon">!</view>
          <view class="warning-text">{{item}}</view>
        </view>
      </view>
      <view class="disclaimer card">{{result.disclaimer}}</view>
      <view class="content-note card">
        <view class="content-note-title">内容说明</view>
        <view class="content-note-text">{{result.contentBoundaryNotice}}</view>
      </view>
    </view>

    <view wx:if="{{result.relatedQuestionItems.length}}" class="section">
      <view class="section-head">
        <view class="section-title">相关问题</view>
      </view>
      <view class="related-grid">
        <view wx:for="{{result.relatedQuestionItems}}" wx:key="id" class="tap-card related-card card" bindtap="goQuestion" data-id="{{item.id}}">
          <view class="related-title">{{item.shortTitle}}</view>
          <view class="related-sub">{{item.summary}}</view>
          <view class="related-arrow">›</view>
        </view>
      </view>
    </view>
  </block>
</view>
