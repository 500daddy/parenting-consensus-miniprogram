<view class="page with-tab result-page">
  <view class="result-search card">
    <view class="result-search-main" bindtap="goSearch" aria-label="重新搜索育儿问题">
      <view class="search-icon"></view>
      <view class="result-keyword">{{keyword || '搜索育儿问题'}}</view>
    </view>
    <view wx:if="{{!noResult}}" class="change-btn" bindtap="changeQuestion">换一个</view>
  </view>

  <view wx:if="{{noResult}}" class="empty-card card">
    <image class="empty-icon pixel-img" src="{{actionIconPaths.question}}" mode="aspectFit" />
    <view class="empty-copy">
      <view class="empty-title">暂时没有找到精确共识</view>
      <view class="empty-desc">可以把这个问题加入待补充池。请尽量写成完整问题，例如：宝宝夜里频繁醒怎么办？</view>
    </view>
    <view class="empty-actions">
      <button class="btn-plain primary-button" bindtap="submitMissingQuestion">提交这个问题</button>
      <button class="btn-plain secondary-button" bindtap="goSearch">重新搜索</button>
    </view>
  </view>

  <view wx:if="{{noResult && fallbackQuestions.length}}" class="section">
    <view class="section-head">
      <view class="section-title">先看看这些问题</view>
    </view>
    <view class="related-grid">
      <view wx:for="{{fallbackQuestions}}" wx:key="id" class="tap-card related-card card" bindtap="goQuestion" data-id="{{item.id}}">
        <view class="related-top">
          <image class="related-icon pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
          <text class="related-tag">{{item.tag}}</text>
        </view>
        <view class="related-title">{{item.shortTitle}}</view>
        <view class="related-sub">{{item.summary}}</view>
        <view class="related-footer">
          <text>查看答案</text>
          <view class="related-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <block wx:if="{{result}}">
    <view class="answer-hero card">
      <view class="answer-topline">
        <view class="current-question-label">当前问题</view>
        <view class="judgement-pill tone-{{result.judgementTone}}">{{result.primaryJudgement}}</view>
      </view>
      <view class="answer-question-title">{{result.question.title}}</view>
      <view class="current-question-meta">
        <text>{{result.question.categoryName}}</text>
        <text>{{result.question.scene}}</text>
        <text>{{result.question.riskLevel}}风险</text>
      </view>

      <view class="answer-box">
        <view class="answer-box-head">
          <image class="badge pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" />
          <view class="answer-head-copy">
            <view class="answer-box-title">多数观点</view>
            <view class="answer-box-label">综合整理，仍需结合宝宝情况</view>
          </view>
        </view>
        <view class="conclusion-text answer-text">
          <block wx:for="{{result.conclusionSegments}}" wx:key="index">
            <text wx:if="{{item.entry}}" class="glossary-term" data-term="{{item.term}}" catchtap="showGlossary">{{item.text}}</text>
            <text wx:else>{{item.text}}</text>
          </block>
        </view>
      </view>

      <view wx:if="{{result.riskNotice}}" class="risk-notice hero-risk">
        <image class="risk-icon pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" />
        <view class="risk-copy">
          <view class="risk-title">{{result.isHighRisk || result.riskLevel === '高' ? '优先看风险' : '健康提醒'}}</view>
          <view class="risk-text">{{result.riskNotice}}</view>
        </view>
      </view>

      <view wx:if="{{result.profileHint}}" class="profile-hint">
        <image class="profile-hint-icon pixel-img" src="{{actionIconPaths.reminder}}" mode="aspectFit" />
        <view class="profile-hint-main">
          <view class="profile-hint-head">
            <view class="profile-hint-title">{{result.profileHint.title}}</view>
            <view wx:if="{{result.profileHint.meta}}" class="profile-hint-meta">{{result.profileHint.meta}}</view>
          </view>
          <view class="profile-hint-text">{{result.profileHint.text}}</view>
          <view wx:if="{{result.profileHint.actionText}}" class="profile-hint-action" bindtap="goProfile">{{result.profileHint.actionText}}</view>
        </view>
      </view>

      <view wx:if="{{result.tools && result.tools.length}}" class="tool-float-entry" bindtap="toggleToolPanel">
        <image class="tool-float-icon pixel-img" src="{{actionIconPaths.tools}}" mode="aspectFit" />
        <view class="tool-float-copy">
          <view class="tool-float-title">可用小工具</view>
          <view class="tool-float-sub">{{result.tools.length}} 个，点开选择</view>
        </view>
        <view class="tool-float-action">{{isToolPanelOpen ? '收起' : '打开'}}</view>
      </view>

      <view wx:if="{{isToolPanelOpen}}" class="tool-panel-mask" catchtap="closeToolPanel">
        <view class="tool-panel card" catchtap="noop">
          <view class="tool-panel-head">
            <view>
              <view class="tool-panel-title">选择小工具</view>
              <view class="tool-panel-sub">根据当前问题推荐，可按需打开</view>
            </view>
            <view class="tool-panel-close" catchtap="closeToolPanel">×</view>
          </view>
          <view class="tool-panel-list">
            <tool-card wx:for="{{result.tools}}" wx:key="id" tool="{{item}}" bind:select="openTool" />
          </view>
          <view class="tool-panel-more" bindtap="goToolRecords">
            <view>
              <view class="tool-panel-more-title">还有更多小工具</view>
              <view class="tool-panel-more-sub">可以查看已保存记录，也可以新建其他记录工具。</view>
            </view>
            <view class="tool-panel-more-action">去查看</view>
          </view>
        </view>
      </view>

      <view class="answer-footer">
        <view class="summary-meta">{{result.dataSourceNote}}</view>
        <view class="summary-actions weak-actions">
          <button class="btn-plain summary-action-btn share-action-btn" open-type="share" aria-label="分享当前问题">
            <image class="summary-action-icon pixel-img" src="{{actionIconPaths.share}}" mode="aspectFit" />
            <text>分享</text>
          </button>
          <button class="btn-plain summary-action-btn favorite-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite" aria-label="{{isFavorite ? '取消收藏' : '收藏'}}">
            <image class="summary-action-icon favorite-icon pixel-img" src="{{isFavorite ? actionIconPaths.star : actionIconPaths.favorite}}" mode="aspectFit" />
            <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
          </button>
        </view>
      </view>
    </view>

    <view class="section explanation-section">
      <view class="section-head">
        <view class="section-title">不同观点在说什么</view>
        <view class="section-hint">作为补充参考</view>
      </view>
      <view class="viewpoint-list">
        <view wx:for="{{result.viewpoints}}" wx:key="id" class="viewpoint-card card">
          <view class="viewpoint-head">
            <view class="viewpoint-name">
              <view class="dot" style="background: {{item.color}};"></view>
              <text>{{item.displayTitle}}</text>
            </view>
            <view class="viewpoint-percent" style="color: {{item.color}};">{{item.percentage}}%</view>
          </view>
          <view class="viewpoint-text">{{item.summary}}</view>
          <view class="viewpoint-track">
            <view class="viewpoint-fill" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title"><image class="question-mark pixel-img" src="{{actionIconPaths.question}}" mode="aspectFit" /><text>为什么这么认为</text></view>
      <view class="reason-grid">
        <view wx:for="{{result.reasons}}" wx:key="id" class="reason-card tone-{{item.tone}}">
          <image class="reason-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
          <view class="reason-title">{{item.title}}</view>
          <view class="reason-desc">{{item.description}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title"><image class="shield-small pixel-img" src="{{actionIconPaths.authority}}" mode="aspectFit" /><text>权威内容推荐</text></view>
      </view>
      <view wx:if="{{result.authorityView}}" class="authority-view card">
        <view class="authority-view-label">权威观点</view>
        <view class="authority-view-text">{{result.authorityView}}</view>
      </view>
      <view class="authority-list">
        <view wx:for="{{result.authoritySources}}" wx:key="id" class="authority-row card">
          <image class="authority-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
          <view class="authority-main">
            <view class="authority-head">
              <view class="authority-title">{{item.typeName}}</view>
              <text class="trust-dot">{{item.trustLabel}}</text>
            </view>
            <view class="authority-summary">{{item.summary}}</view>
            <view class="authority-tags">
              <text wx:for="{{item.tags}}" wx:key="*this" class="authority-tag">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title"><image class="warn-mark pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" /><text>安全提醒</text></view>
      <view wx:if="{{result.safetyNotice}}" class="safety-notice card">{{result.safetyNotice}}</view>
      <view class="warning-grid">
        <view wx:for="{{result.warnings}}" wx:key="*this" class="warning-tile warning-{{index}}">
          <view class="warning-icon">!</view>
          <view class="warning-text">{{item}}</view>
        </view>
      </view>
      <view class="disclaimer card">{{result.disclaimer}}</view>
      <view class="content-note card">
        <view class="content-note-title">内容说明</view>
        <view class="content-note-text">{{result.contentBoundaryNotice}}</view>
      </view>
    </view>

    <view wx:if="{{result.relatedQuestionItems.length}}" class="section">
      <view class="section-head">
        <view class="section-title">相关问题</view>
        <view class="section-hint section-link" bindtap="goSearch">更多问题</view>
      </view>
      <view class="related-grid">
        <view wx:for="{{result.relatedQuestionItems}}" wx:key="id" class="tap-card related-card card" bindtap="goQuestion" data-id="{{item.id}}">
          <view class="related-top">
            <image class="related-icon pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
            <text class="related-tag">{{item.tag}}</text>
          </view>
          <view class="related-title">{{item.shortTitle}}</view>
          <view class="related-sub">{{item.relatedSummary}}</view>
          <view class="related-footer">
            <text>查看答案</text>
            <view class="related-arrow">›</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{glossaryPopup}}" class="glossary-mask" catchtap="hideGlossary">
    <view class="glossary-pop card" catchtap="noop">
      <view class="glossary-head">
        <view class="glossary-title">{{glossaryPopup.title}}</view>
        <view class="glossary-close" catchtap="hideGlossary">×</view>
      </view>
      <view class="glossary-summary">{{glossaryPopup.summary}}</view>
      <view class="glossary-reminder">{{glossaryPopup.reminder}}</view>
    </view>
  </view>
</view>
