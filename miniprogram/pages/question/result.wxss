  color: #746b62;
  font-size: 24rpx;
  line-height: 1.45;
}

.reason-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.reason-card {
  min-height: 156rpx;
  padding: 20rpx;
  border: 2rpx solid #ead8b8;
  border-radius: 16rpx;
  background: #fffdf6;
  text-align: left;
}

.reason-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 14rpx;
  border-radius: 10rpx;
}

.reason-title {
  min-height: 0;
  color: #2f2a25;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 700;
}

.reason-desc {
  margin-top: 10rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.42;
}

.tone-green .reason-icon {
  background: #eef6ea;
  color: #7ea66a;
}

.tone-orange .reason-icon {
  background: #fff4e4;
  color: #f4a340;
}

.tone-red .reason-icon {
  background: #fff0ec;
  color: #f36f5b;
}

.tone-purple .reason-icon {
  background: #f4efff;
  color: #a78bdc;
}

.authority-view {
  width: 100%;
  padding: 22rpx;
  background: #fffaf3;
  border-color: #ead8b8;
}

.authority-view-label {
  color: #7a5d28;
  font-size: 23rpx;
  font-weight: 700;
}

.authority-view-text {
  margin-top: 8rpx;
  color: #4a3a2c;
  font-size: 25rpx;
  line-height: 1.5;
}

.reference-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  padding: 22rpx;
  background: #fffaf3;
  border-color: #ead8b8;
}

.reference-main {
  flex: 1;
  min-width: 0;
}

.reference-title {
  color: #4a3a2c;
  font-size: 25rpx;
  line-height: 1.42;
  font-weight: 700;
}

.reference-sub {
  margin-top: 6rpx;
  color: #8a8177;
  font-size: 22rpx;
  line-height: 1.35;
}

.reference-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 23rpx;
  font-weight: 800;
  flex: none;
}

.authority-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
}

.compact-authority-list {
  margin-top: 14rpx;
}

.authority-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  width: 100%;
  padding: 22rpx;
  background: #fffdf6;
  border-color: #ead8b8;
  text-align: left;
}

.compact-authority-row {
  padding: 18rpx 20rpx;
}

.authority-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  flex: none;
}

.authority-main {
  flex: 1;
  min-width: 0;
}

.authority-head {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.authority-title {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 700;
}

.trust-dot {
  flex: none;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 22rpx;
}

.authority-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 23rpx;
  line-height: 1.35;
}

.authority-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.authority-tag {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #f2f8ef;
  color: #6f985a;
  font-size: 22rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}

.minority-card {
  width: 100%;
  padding: 24rpx;
  background: #fcf8ff;
  border-color: #eadff8;
}

.minority-title {
  color: #6f55a5;
  font-size: 30rpx;
  font-weight: 700;
}

.minority-text {
  margin-top: 12rpx;
  color: #554c5f;
  font-size: 26rpx;
  line-height: 1.55;
}

.safety-notice {
  margin-top: 16rpx;
  padding: 22rpx;
  color: #9f422f;
  font-size: 25rpx;
  line-height: 1.5;
  background: #fff1ea;
  border-color: #f1b59c;
}

.warning-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.warning-tile {
  min-height: 86rpx;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx;
  border: 2rpx solid #f7d9c6;
  border-radius: 14rpx;
  background: #fff7f1;
  color: #b86146;
  font-size: 23rpx;
  line-height: 1.25;
  text-align: left;
}

.warning-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 9rpx;
  background: #f36f5b;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.warning-1 .warning-icon,
.warning-3 .warning-icon {
  background: #f4a340;
}

.warning-text {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.disclaimer {
  margin-top: 16rpx;
  padding: 22rpx;
  color: #8b5a46;
  font-size: 24rpx;
  line-height: 1.55;
  background: #fffaf3;
  border-color: #ead8b8;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
}

.related-card {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  width: 100%;
  min-height: 218rpx;
  padding: 20rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: left;
}

.related-card:active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

.related-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.related-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #f7fbf2;
  flex: none;
}

.related-tag {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 20rpx;
  font-weight: 900;
}

.related-title {
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.28;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-sub {
  margin-top: 10rpx;
  color: #7d746c;
  font-size: 23rpx;
  line-height: 1.4;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.related-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 16rpx;
  color: #4f8a43;
  font-size: 22rpx;
  font-weight: 900;
}

.related-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 30rpx;
  line-height: 1;
  flex: none;
}

@media (max-width: 360px) {
  .summary-actions.weak-actions {
    width: 100%;
  }

  .summary-actions.weak-actions .summary-action-btn {
    flex: 1;
    width: auto;
    min-width: 0;
  }

  .chart-card {
    align-items: flex-start;
  }

  .donut-wrap,
  .donut {
    width: 136rpx;
    height: 136rpx;
  }

  .donut-inner {
    left: 29rpx;
    top: 29rpx;
    width: 78rpx;
    height: 78rpx;
    font-size: 21rpx;
  }

  .bar-row {
    grid-template-columns: 1fr 58rpx;
    gap: 10rpx;
  }

  .bar-label {
    grid-column: 1 / 3;
  }
}
