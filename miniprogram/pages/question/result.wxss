  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: #f8d79e;
  color: #7d4819;
  box-shadow: inset 0 -3rpx 0 rgba(135, 79, 28, 0.12);
}

.share-action-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 18rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
  background: rgba(255, 250, 240, 0.34);
  transform: translateX(-50%);
}

.share-action-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 7rpx;
  width: 4rpx;
  height: 17rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.share-action-icon .share-arrow-head {
  position: absolute;
  display: block;
  left: 50%;
  top: 5rpx;
  width: 12rpx;
  height: 12rpx;
  box-sizing: border-box;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
