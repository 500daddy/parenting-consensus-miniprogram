.pixel-img {
  display: block;
}

.result-search {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  margin-top: 18rpx;
  background: #fffdf6;
  border-color: #ead8b8;
  box-shadow: 0 6rpx 0 rgba(183, 143, 83, 0.1), 0 12rpx 24rpx rgba(80, 60, 40, 0.05);
}

.result-keyword {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 29rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.change-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 54rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 24rpx;
  font-weight: 600;
  flex: none;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-top: 28rpx;
  padding: 34rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 20rpx;
  border-radius: 14rpx;
  background: #fff4e4;
  color: #f4a340;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-copy {
  width: 100%;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 26rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-card .primary-button {
  min-width: 200rpx;
}

.summary-card {
  width: 100%;
  margin-top: 22rpx;
  padding: 26rpx;
  background: #fffdf6;
  border-color: #ead8b8;
}

.summary-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.page.with-tab.result-page::after {
  bottom: calc(104rpx + env(safe-area-inset-bottom));
  height: 72rpx;
  background: linear-gradient(180deg, rgba(255, 248, 236, 0) 0%, rgba(255, 248, 236, 0.54) 64%, rgba(255, 253, 246, 0.92) 100%);
}

.badge,
.shield-small,
.question-mark,
.warn-mark {
  width: 42rpx;
  height: 42rpx;
  border-radius: 10rpx;
  flex: none;
}

.badge,
.shield-small {
  background: #f4a340;
}

.question-mark {
  background: #f4a340;
}

.warn-mark {
  background: #f36f5b;
}

.summary-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
}

.favorite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 128rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border: 2rpx solid #f3d6ac;
  border-radius: 999rpx;
  background: #fff4e4;
  color: #d9821f;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 54rpx;
  flex: none;
}

.favorite-btn.active {
  border-color: #cfe3c4;
  background: #eaf6df;
  color: #4f8a43;
}

.favorite-icon {
  width: 32rpx;
  height: 32rpx;
  flex: none;
}

.conclusion-box {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #cfe3c4;
  border-radius: 16rpx;
  background: #f3faee;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #7ea66a;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  flex: none;
}

.conclusion-text {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.58;
  font-weight: 600;
}

.summary-meta,
.sample-note {
  margin-top: 18rpx;
  color: #8b8178;
  font-size: 24rpx;
  line-height: 1.4;
}

.chart-title {
  margin-top: 22rpx;
  color: #2f2a25;
  font-size: 28rpx;
  font-weight: 700;
}

.chart-card {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 20rpx;
  border: 2rpx solid #ead8b8;
  border-radius: 16rpx;
  background: #fffaf0;
}

.donut-wrap {
  width: 160rpx;
  height: 160rpx;
  flex: none;
}

.donut {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: conic-gradient(#7ea66a 0 68%, #f4a340 68% 89%, #f36f5b 89% 100%);
}

.donut-inner {
  position: absolute;
  left: 34rpx;
  top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #fffdf6;
  color: #2f2a25;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
}

.bars {
  flex: 1;
  min-width: 0;
}

.bar-row {
  display: grid;
  grid-template-columns: 160rpx 1fr 66rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 54rpx;
}

.bar-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  color: #2f2a25;
  font-size: 23rpx;
}

.bar-label text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bar-track {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f1ece6;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex: none;
}

.bar-percent {
  text-align: right;
  font-size: 25rpx;
  font-weight: 700;
}

.reason-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.reason-card {
  min-height: 156rpx;
  padding: 20rpx;
  border: 2rpx solid #ead8b8;
  border-radius: 16rpx;
  background: #fffdf6;
  text-align: left;
}

.reason-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 14rpx;
  border-radius: 10rpx;
}

.reason-title {
  min-height: 0;
  color: #2f2a25;
  font-size: 25rpx;
  line-height: 1.3;
  font-weight: 700;
}

.reason-desc {
  margin-top: 10rpx;
  color: #756d66;
  font-size: 22rpx;
  line-height: 1.42;
}

.tone-green .reason-icon {
  background: #eef6ea;
  color: #7ea66a;
}

.tone-orange .reason-icon {
  background: #fff4e4;
  color: #f4a340;
}

.tone-red .reason-icon {
  background: #fff0ec;
  color: #f36f5b;
}

.tone-purple .reason-icon {
  background: #f4efff;
  color: #a78bdc;
}

.authority-view {
  width: 100%;
  padding: 22rpx;
  background: #fffaf3;
  border-color: #ead8b8;
}

.authority-view-label {
  color: #7a5d28;
  font-size: 22rpx;
  font-weight: 700;
}

.authority-view-text {
  margin-top: 8rpx;
  color: #4a3a2c;
  font-size: 25rpx;
  line-height: 1.5;
}

.authority-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
}

.authority-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  width: 100%;
  padding: 22rpx;
  background: #fffdf6;
  border-color: #ead8b8;
  text-align: left;
}

.authority-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  flex: none;
}

.authority-main {
  flex: 1;
  min-width: 0;
}

.authority-head {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.authority-title {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 700;
}

.trust-dot {
  flex: none;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 20rpx;
}

.authority-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 23rpx;
  line-height: 1.35;
}

.authority-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.authority-tag {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #f2f8ef;
  color: #6f985a;
  font-size: 20rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}

.minority-card {
  width: 100%;
  padding: 24rpx;
  background: #fcf8ff;
  border-color: #eadff8;
}

.minority-title {
  color: #6f55a5;
  font-size: 30rpx;
  font-weight: 700;
}

.minority-text {
  margin-top: 12rpx;
  color: #554c5f;
  font-size: 26rpx;
  line-height: 1.55;
}

.safety-notice {
  margin-top: 16rpx;
  padding: 22rpx;
  color: #9f422f;
  font-size: 25rpx;
  line-height: 1.5;
  background: #fff1ea;
  border-color: #f1b59c;
}

.warning-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.warning-tile {
  min-height: 86rpx;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-start;
  padding: 16rpx;
  border: 2rpx solid #f7d9c6;
  border-radius: 14rpx;
  background: #fff7f1;
  color: #b86146;
  font-size: 23rpx;
  line-height: 1.25;
  text-align: left;
}

.warning-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 9rpx;
  background: #f36f5b;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.warning-1 .warning-icon,
.warning-3 .warning-icon {
  background: #f4a340;
}

.warning-text {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}

.disclaimer {
  margin-top: 16rpx;
  padding: 22rpx;
  color: #8b5a46;
  font-size: 24rpx;
  line-height: 1.55;
  background: #fffaf3;
  border-color: #ead8b8;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
}

.related-card {
  position: relative;
  width: 100%;
  min-height: 140rpx;
  padding: 22rpx 64rpx 22rpx 22rpx;
  text-align: left;
}

.related-title {
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
}

.related-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 22rpx;
  line-height: 1.35;
}

.related-arrow {
  position: absolute;
  right: 18rpx;
  top: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 34rpx;
}

@media (max-width: 360px) {
  .chart-card {
    align-items: flex-start;
  }

  .donut-wrap,
  .donut {
    width: 136rpx;
    height: 136rpx;
  }

  .donut-inner {
    left: 29rpx;
    top: 29rpx;
    width: 78rpx;
    height: 78rpx;
    font-size: 21rpx;
  }

  .bar-row {
    grid-template-columns: 1fr 58rpx;
    gap: 10rpx;
  }

  .bar-label {
    grid-column: 1 / 3;
  }
}
