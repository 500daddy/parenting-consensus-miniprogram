.result-search {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  margin-top: 10rpx;
}

.result-keyword {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 29rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.change-btn {
  color: #7ea66a;
  font-size: 24rpx;
}

.empty-card {
  margin-top: 28rpx;
  padding: 34rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 26rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.summary-card {
  width: 100%;
  margin-top: 22rpx;
  padding: 26rpx;
}

.summary-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.badge,
.shield-small,
.question-mark,
.warn-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.badge,
.shield-small {
  background: #f4a340;
}

.question-mark {
  background: #f4a340;
}

.warn-mark {
  background: #f36f5b;
}

.summary-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
}

.favorite-btn {
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff4e4;
  color: #d9821f;
  font-size: 24rpx;
}

.favorite-btn.active {
  background: #eef6ea;
  color: #6f985a;
}

.conclusion-box {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f2f8ef;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #7ea66a;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  flex: none;
}

.conclusion-text {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.58;
  font-weight: 600;
}

.summary-meta,
.sample-note {
  margin-top: 18rpx;
  color: #8b8178;
  font-size: 24rpx;
  line-height: 1.4;
}

.quick-action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.quick-view {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef6ea;
  color: #5f8c4a;
  font-size: 22rpx;
}

.quick-view text {
  font-weight: 700;
}

.quick-1 {
  background: #fff4e4;
  color: #c17442;
}

.quick-2 {
  background: #fff0ec;
  color: #c75e4f;
}

.chart-title {
  margin-top: 22rpx;
  color: #2f2a25;
  font-size: 28rpx;
  font-weight: 700;
}

.chart-card {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #eee6dc;
  border-radius: 20rpx;
  background: #fffdfb;
}

.donut-wrap {
  width: 160rpx;
  height: 160rpx;
  flex: none;
}

.donut {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: conic-gradient(#7ea66a 0 68%, #f4a340 68% 89%, #f36f5b 89% 100%);
}

.donut-inner {
  position: absolute;
  left: 34rpx;
  top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #2f2a25;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
}

.bars {
  flex: 1;
  min-width: 0;
}

.bar-row {
  display: grid;
  grid-template-columns: 160rpx 1fr 66rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 54rpx;
}

.bar-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  color: #2f2a25;
  font-size: 23rpx;
}

.bar-label text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bar-track {
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f1ece6;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.fill-0,
.dot-0 {
  background: #7ea66a;
}

.fill-1,
.dot-1 {
  background: #f4a340;
}

.fill-2,
.dot-2 {
  background: #f36f5b;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex: none;
}

.bar-percent {
  text-align: right;
  font-size: 25rpx;
  font-weight: 700;
}

.percent-0 {
  color: #7ea66a;
}

.percent-1 {
  color: #f4a340;
}

.percent-2 {
  color: #f36f5b;
}

.reason-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.reason-card {
  min-height: 170rpx;
  padding: 18rpx 14rpx;
  border: 1rpx solid #eee6dc;
  border-radius: 18rpx;
  background: #fffdfb;
  text-align: left;
}

.reason-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  background: #eef6ea;
  font-size: 30rpx;
  font-weight: 700;
}

.reason-title {
  min-height: 0;
  color: #2f2a25;
  font-size: 23rpx;
  line-height: 1.3;
  font-weight: 700;
}

.reason-desc {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 20rpx;
  line-height: 1.35;
}

.tone-green .reason-icon {
  background: #eef6ea;
  color: #7ea66a;
}

.tone-orange .reason-icon {
  background: #fff4e4;
  color: #f4a340;
}

.tone-red .reason-icon {
  background: #fff0ec;
  color: #f36f5b;
}

.tone-purple .reason-icon {
  background: #f4efff;
  color: #a78bdc;
}

.authority-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
}

.authority-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  padding: 20rpx 22rpx;
  text-align: left;
}

.authority-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 30rpx;
  font-weight: 700;
  flex: none;
}

.authority-main {
  flex: 1;
  min-width: 0;
}

.authority-title {
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
}

.trust-dot {
  margin-left: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 20rpx;
}

.authority-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 23rpx;
  line-height: 1.35;
}

.row-arrow {
  color: #9a938b;
  font-size: 42rpx;
}

.minority-card {
  width: 100%;
  padding: 24rpx;
  background: #fcf8ff;
  border-color: #eadff8;
}

.minority-title {
  color: #6f55a5;
  font-size: 30rpx;
  font-weight: 700;
}

.minority-text {
  margin-top: 12rpx;
  color: #554c5f;
  font-size: 26rpx;
  line-height: 1.55;
}

.warning-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.warning-tile {
  min-height: 92rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  border: 1rpx solid #f7d9c6;
  border-radius: 16rpx;
  background: #fff7f1;
  color: #b86146;
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
}

.warning-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f36f5b;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.warning-1 .warning-icon,
.warning-3 .warning-icon {
  background: #f4a340;
}

.disclaimer {
  margin-top: 16rpx;
  padding: 22rpx;
  color: #8b5a46;
  font-size: 24rpx;
  line-height: 1.55;
  background: #fffaf3;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
}

.related-card {
  position: relative;
  width: 100%;
  min-height: 140rpx;
  padding: 22rpx 64rpx 22rpx 22rpx;
  text-align: left;
}

.related-title {
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
}

.related-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 22rpx;
  line-height: 1.35;
}

.related-arrow {
  position: absolute;
  right: 18rpx;
  top: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 34rpx;
}

@media (max-width: 360px) {
  .chart-card {
    align-items: flex-start;
  }

  .donut-wrap,
  .donut {
    width: 136rpx;
    height: 136rpx;
  }

  .donut-inner {
    left: 29rpx;
    top: 29rpx;
    width: 78rpx;
    height: 78rpx;
    font-size: 21rpx;
  }

  .bar-row {
    grid-template-columns: 1fr 58rpx;
    gap: 10rpx;
  }

  .bar-label {
    grid-column: 1 / 3;
  }
}
