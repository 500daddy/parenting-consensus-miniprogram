.pixel-img {
  display: block;
}

.home-page {
  padding-top: 0;
}

.home-page::before {
  display: none;
}

.hero {
  min-height: 336rpx;
  margin: 0 -26rpx;
  padding: 112rpx 44rpx 30rpx;
  border: 0;
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 0 rgba(183, 143, 83, 0.1), 0 16rpx 26rpx rgba(92, 65, 36, 0.05);
}

.hero-photo,
.hero-scrim {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.hero-photo {
  z-index: 0;
}

.hero-scrim {
  z-index: 1;
  background:
    linear-gradient(180deg, rgba(31, 34, 23, 0.3) 0%, rgba(31, 34, 23, 0.06) 46%, rgba(31, 34, 23, 0) 100%),
    linear-gradient(90deg, rgba(36, 39, 26, 0.36) 0%, rgba(36, 39, 26, 0.12) 38%, rgba(36, 39, 26, 0) 70%);
}

.hero-copy {
  position: absolute;
  right: 34rpx;
  z-index: 2;
  width: 246rpx;
}

.hero-sign {
  filter: drop-shadow(0 8rpx 0 rgba(77, 52, 30, 0.18));
}

.sign-roof {
  width: 78rpx;
  height: 18rpx;
  margin-left: 22rpx;
  border: 3rpx solid #7e5430;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
  background: #b86833;
  box-shadow: inset 0 -5rpx 0 rgba(93, 52, 26, 0.16);
}

.sign-board {
  position: relative;
  padding: 10rpx 16rpx 12rpx;
  border: 4rpx solid #7e5430;
  border-radius: 8rpx;
  background: #f4d58f;
  box-shadow: inset 0 -7rpx 0 rgba(162, 105, 48, 0.18), 0 5rpx 0 #7e5430;
}

.sign-board::before,
.sign-board::after {
  content: "";
  position: absolute;
  top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: #8d6132;
}

.sign-board::before {
  left: 12rpx;
}

.sign-board::after {
  right: 12rpx;
}

.sign-tag {
  width: 214rpx;
  margin: 7rpx auto 0;
  padding: 6rpx 10rpx 7rpx;
  border: 3rpx solid #8d6132;
  border-radius: 6rpx;
  background: #f9e8b7;
  box-shadow: 0 4rpx 0 rgba(126, 84, 48, 0.35);
}

.hero-title {
  color: #4d3a25;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.08;
  text-align: center;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.55);
}

.hero-subtitle {
  color: #6b4b2d;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
}

.search-panel {
  margin-top: -38rpx;
  padding: 10rpx;
  border-radius: 18rpx;
  position: relative;
  z-index: 3;
}

.search-panel .search-card {
  min-height: 82rpx;
  border-radius: 12rpx;
  background: #fffdf6;
  padding-right: 10rpx;
}

.home-search-input {
  flex: 1;
  min-width: 0;
  color: #aaa19a;
  font-size: 26rpx;
  height: 76rpx;
  line-height: 1.35;
  text-align: left;
}

.home-search-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  min-width: 96rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: #75b86f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 60rpx;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.18);
  flex: none;
}

.home-page > .section {
  margin-top: 24rpx;
}

.home-page .section-head {
  min-height: 50rpx;
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.home-page .section-title {
  flex: 1;
  min-width: 0;
}

.home-page .section-more {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-width: 132rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border: 2rpx solid #efd6ae;
  border-radius: 999rpx;
  background: #fff8ec;
  color: #9d6a32;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 48rpx;
  box-shadow: 0 3rpx 0 rgba(160, 111, 55, 0.12);
}

.home-page .section-more:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 0 rgba(160, 111, 55, 0.12);
}

.home-page .icon-more {
  min-width: 48rpx;
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  font-size: 32rpx;
  line-height: 44rpx;
}

.chip-icon {
  margin-right: 8rpx;
}

.quick-section {
  margin-top: 18rpx;
}

.quick-title {
  margin-bottom: 12rpx;
  color: #8b8178;
  font-size: 25rpx;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.home-chip {
  width: auto;
  min-width: 0;
  min-height: 96rpx;
  margin-right: 0;
  padding: 12rpx 6rpx 10rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  font-size: 22rpx;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(80, 60, 40, 0.04);
}

.home-chip .chip-icon {
  width: 46rpx;
  height: 46rpx;
  margin-right: 0;
  border-radius: 12rpx;
}

.section-mark {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  flex: none;
}

.cat-2 .chip-icon,
.cat-5 .chip-icon {
  background: #fff4e4;
  color: #d9821f;
}

.cat-1 .chip-icon,
.cat-6 .chip-icon {
  background: #eef4ff;
  color: #6b91d6;
}

.cat-7 .chip-icon {
  background: #f4efff;
  color: #8d75c9;
}

.fire-mark,
.shield-mark,
.idea-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.fire-mark {
  background: #f36f5b;
}

.shield-mark {
  background: #9a7236;
}

.idea-mark {
  background: #f4a340;
}

.hot-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hot-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  min-height: 138rpx;
  padding: 18rpx;
  text-align: left;
  background: #fffdf6;
}

.hot-card .tag {
  min-height: 34rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
}

.hot-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex: none;
}

.hot-main {
  flex: 1;
  min-width: 0;
}

.hot-title {
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  white-space: normal;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.hot-summary {
  margin-top: 6rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.hot-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  color: #8b8178;
  font-size: 22rpx;
}

.hot-more-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: fit-content;
  min-width: 220rpx;
  height: 56rpx;
  margin: 18rpx auto 0;
  padding: 0 22rpx;
  border: 2rpx solid #d8e8cf;
  border-radius: 999rpx;
  background: #f7fbf2;
  color: #4f8a43;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 4rpx 0 rgba(111, 152, 90, 0.1);
}

.hot-more-tip:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 0 rgba(111, 152, 90, 0.1);
}

.hot-more-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid #4f8a43;
  border-right: 4rpx solid #4f8a43;
  transform: rotate(45deg);
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}

.consensus-card {
  width: 100%;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  text-align: left;
  margin-bottom: 0;
  background: linear-gradient(180deg, #fffdf6 0%, #fff9ef 100%);
}

.consensus-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  flex: none;
}

.consensus-main {
  flex: 1;
  min-width: 0;
}

.consensus-title {
  font-size: 32rpx;
  line-height: 1.32;
  font-weight: 800;
  color: #2f2a25;
}

.consensus-conclusion {
  margin-top: 12rpx;
  color: #5b5149;
  font-size: 26rpx;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.glossary-term {
  color: #4f7f45;
  font-weight: 700;
  border-bottom: 2rpx solid #7ea66a;
  padding-bottom: 1rpx;
}

.glossary-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(47, 42, 37, 0.36);
}

.glossary-pop {
  width: 100%;
  max-height: 72vh;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #fffdf6;
  border-color: #ead8b8;
  overflow: auto;
}

.glossary-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.glossary-title {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 800;
}

.glossary-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  color: #8b8178;
  font-size: 30rpx;
  font-weight: 800;
  flex: none;
}

.glossary-summary {
  margin-top: 18rpx;
  color: #4f453c;
  font-size: 27rpx;
  line-height: 1.55;
}

.glossary-reminder {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f5fbf1;
  color: #5f8c4a;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 700;
}

.stack-bar {
  display: flex;
  height: 22rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eee6dc;
}

.stack-seg {
  height: 100%;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-top: 10rpx;
}

.legend-row.compact {
  gap: 8rpx 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8b8178;
  font-size: 23rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.arrow-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: #fbf3ea;
  color: #c17442;
  font-size: 38rpx;
  flex: none;
}

.safety-inline {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 12rpx 14rpx;
  border: 2rpx solid #f7d9c6;
  border-radius: 14rpx;
  background: #fff7f1;
  color: #b86146;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.safety-icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
}

@media (max-width: 360px) {
  .home-page {
    padding-top: 0;
  }

  .hero {
    min-height: 318rpx;
    padding-top: 104rpx;
  }

  .quick-grid {
    gap: 10rpx;
  }

  .home-chip {
    font-size: 20rpx;
  }

  .hot-card {
    min-height: 128rpx;
  }
}
