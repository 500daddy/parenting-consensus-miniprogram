.home-page {
  padding-top: 0;
}

.home-page::before {
  display: none;
}

.hero {
  min-height: 336rpx;
  margin: 0 -26rpx;
  padding: 112rpx 50rpx 30rpx;
  border: 0;
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 0 rgba(183, 143, 83, 0.1), 0 16rpx 26rpx rgba(92, 65, 36, 0.05);
}

.hero-photo,
.hero-scrim {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.hero-photo {
  z-index: 0;
}

.hero-scrim {
  z-index: 1;
  background: linear-gradient(90deg, rgba(36, 39, 26, 0.5) 0%, rgba(36, 39, 26, 0.22) 42%, rgba(36, 39, 26, 0.02) 100%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  padding-top: 0;
}

.hero-title {
  max-width: 430rpx;
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1.1;
  text-shadow: 0 4rpx 14rpx rgba(46, 36, 24, 0.32);
}

.hero-subtitle {
  max-width: 430rpx;
  color: rgba(255, 255, 255, 0.92);
  text-shadow: 0 3rpx 10rpx rgba(46, 36, 24, 0.3);
}

.search-panel {
  margin-top: -38rpx;
  padding: 10rpx;
  border-radius: 18rpx;
  position: relative;
  z-index: 3;
}

.search-panel .search-card {
  min-height: 82rpx;
  border-radius: 12rpx;
  background: #fffdf6;
  padding-right: 10rpx;
}

.search-placeholder {
  flex: 1;
  min-width: 0;
  color: #aaa19a;
  font-size: 24rpx;
  line-height: 1.35;
  text-align: left;
}

.home-search-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #75b86f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.18);
  flex: none;
}

.home-page > .section {
  margin-top: 26rpx;
}

.home-page .section-head {
  margin-bottom: 14rpx;
}

.chip-icon {
  margin-right: 8rpx;
  color: #7ea66a;
  font-weight: 700;
}

.category-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
}

.home-chip {
  width: 120rpx;
  min-width: 0;
  min-height: 104rpx;
  margin-right: 0;
  padding: 12rpx 8rpx 10rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  font-size: 21rpx;
  flex: none;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 4rpx 14rpx rgba(80, 60, 40, 0.04);
}

.home-chip .chip-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin-right: 0;
  border-radius: 12rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 22rpx;
}

.cat-2 .chip-icon,
.cat-5 .chip-icon {
  background: #fff4e4;
  color: #d9821f;
}

.cat-1 .chip-icon,
.cat-6 .chip-icon {
  background: #eef4ff;
  color: #6b91d6;
}

.cat-7 .chip-icon {
  background: #f4efff;
  color: #8d75c9;
}

.fire-mark,
.shield-mark,
.idea-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.fire-mark {
  background: #f36f5b;
}

.shield-mark {
  background: #9a7236;
}

.idea-mark {
  background: #f4a340;
}

.hot-scroll {
  width: 100%;
  white-space: nowrap;
}

.hot-track {
  display: inline-flex;
  min-width: 100%;
}

.hot-card:last-child,
.source-entry:last-child {
  margin-right: 0;
}

.hot-card {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 226rpx;
  min-height: 198rpx;
  margin-right: 14rpx;
  padding: 20rpx;
  overflow: hidden;
  text-align: left;
  vertical-align: top;
  background: #ffffff;
}

.hot-1 {
  background: #fffdf8;
}

.hot-2 {
  background: #fbfdf8;
}

.hot-card .tag {
  min-height: 34rpx;
  padding: 0 12rpx;
  font-size: 20rpx;
}

.hot-title {
  position: relative;
  z-index: 1;
  min-height: 84rpx;
  color: #2f2a25;
  font-size: 23rpx;
  line-height: 1.36;
  font-weight: 600;
  white-space: normal;
}

.hot-meta {
  position: relative;
  z-index: 1;
  margin: 10rpx 0 10rpx;
  color: #8b8178;
  font-size: 22rpx;
}

.hot-watermark {
  position: absolute;
  right: 18rpx;
  bottom: 8rpx;
  color: rgba(126, 166, 106, 0.16);
  font-size: 78rpx;
  font-weight: 700;
}

.source-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 9rpx;
  padding: 12rpx;
  border: 2rpx solid #ead8b8;
  border-radius: 18rpx;
  background: #fffdf6;
  box-shadow: 0 6rpx 0 rgba(183, 143, 83, 0.08);
}

.source-entry {
  width: 100%;
  min-height: 168rpx;
  padding: 14rpx 8rpx;
  border-radius: 12rpx;
  background: #fbfdf8;
  text-align: center;
}

.source-1 {
  background: #f7faff;
}

.source-2 {
  background: #fffdf5;
}

.source-3 {
  background: #fff9f1;
}

.source-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 8rpx;
  border-radius: 10rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 26rpx;
  font-weight: 700;
}

.source-1 .source-icon {
  background: #edf4ff;
  color: #6b91d6;
}

.source-2 .source-icon {
  background: #f2f8ef;
  color: #6f985a;
}

.source-3 .source-icon {
  background: #fff2dd;
  color: #d9821f;
}

.source-name {
  color: #2f2a25;
  font-size: 22rpx;
  font-weight: 700;
}

.source-desc {
  min-height: 38rpx;
  margin-top: 6rpx;
  color: #8b8178;
  font-size: 18rpx;
  line-height: 1.25;
}

.source-count {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 20rpx;
}

.consensus-card {
  width: 100%;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  text-align: left;
  margin-bottom: 28rpx;
}

.consensus-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #fff2dd;
  color: #f4a340;
  font-size: 32rpx;
  font-weight: 700;
  flex: none;
}

.consensus-main {
  flex: 1;
  min-width: 0;
}

.consensus-title {
  font-size: 28rpx;
  line-height: 1.32;
  font-weight: 700;
  color: #2f2a25;
}

.consensus-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 22rpx;
  line-height: 1.4;
}

.stack-bar {
  display: flex;
  height: 22rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eee6dc;
}

.stack-seg {
  height: 100%;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  margin-top: 10rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8b8178;
  font-size: 21rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.arrow-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  background: #fbf3ea;
  color: #c17442;
  font-size: 38rpx;
  flex: none;
}

@media (max-width: 360px) {
  .home-page {
    padding-top: 0;
  }

  .hero {
    min-height: 318rpx;
    padding-top: 104rpx;
  }

  .source-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
