<view class="page with-tab home-page">
  <view class="hero" style="padding-top: {{heroPaddingTop}}rpx;">
    <image class="hero-photo" src="/assets/hero/village-hero.png" mode="aspectFill" />
    <view class="hero-scrim"></view>
    <view class="hero-copy hero-sign" style="top: {{heroSignTop}}rpx;">
      <view class="sign-roof"></view>
      <view class="sign-board">
        <view class="hero-title">养娃新手村</view>
      </view>
      <view class="sign-tag">
        <view class="hero-subtitle">养娃路上，先来村里问问</view>
      </view>
    </view>
  </view>

  <view class="search-panel card">
    <view class="search-card">
      <view class="search-icon"></view>
      <input class="search-input home-search-input" value="{{homeKeyword}}" placeholder="来村里问问，例如：宝宝发烧能洗澡吗？" confirm-type="search" bindinput="onHomeInput" bindconfirm="searchHome" />
      <view class="home-search-action" bindtap="searchHome">搜索</view>
    </view>
  </view>

  <view class="quick-section">
    <view class="quick-title">常问场景</view>
    <view class="quick-grid">
      <view wx:for="{{categories}}" wx:key="id" class="tap-card chip home-chip cat-{{index}}" bindtap="goCategory" data-id="{{item.id}}">
        <image class="chip-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><image class="section-mark pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" /><text>今日村内公告</text></view>
    </view>
    <view class="tap-card consensus-card card" bindtap="goToday">
      <image class="consensus-icon pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" />
      <view class="consensus-main">
        <view class="consensus-title">{{todayResult.title}}</view>
        <view class="consensus-conclusion">
          <block wx:for="{{todayResult.conclusionSegments}}" wx:key="index">
            <text wx:if="{{item.entry}}" class="glossary-term" data-term="{{item.term}}" catchtap="showGlossary">{{item.text}}</text>
            <text wx:else>{{item.text}}</text>
          </block>
        </view>
        <view class="stack-bar">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="stack-seg" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
        </view>
        <view class="legend-row compact">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="legend-item">
            <view class="dot" style="background: {{item.color}};"></view>
            <text>{{item.percentage}}%</text>
          </view>
        </view>
        <view wx:if="{{primaryWarning}}" class="safety-inline">
          <image class="safety-icon pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" />
          <text>{{primaryWarning}}</text>
        </view>
      </view>
      <view class="arrow-pill"></view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><image class="section-mark pixel-img" src="{{actionIconPaths.hot}}" mode="aspectFit" /><text>大家在问</text></view>
      <button class="btn-plain section-more icon-more" aria-label="查看更多大家在问" bindtap="goSearch"></button>
    </view>
    <view class="hot-list">
      <view wx:for="{{hotQuestions}}" wx:key="id" class="tap-card hot-card hot-{{index}} card" bindtap="goQuestion" data-id="{{item.id}}">
        <image class="hot-icon pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
        <view class="hot-main">
          <view class="hot-title">{{item.shortTitle}}</view>
          <view class="hot-summary">{{item.summary}}</view>
          <view class="hot-meta"><text class="tag">{{item.tag}}</text><text>{{item.heatText}}热度</text></view>
        </view>
        <view class="row-arrow"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{glossaryPopup}}" class="glossary-mask" catchtap="hideGlossary">
    <view class="glossary-pop card" catchtap="noop">
      <view class="glossary-head">
        <view class="glossary-title">{{glossaryPopup.title}}</view>
        <view class="glossary-close" catchtap="hideGlossary">×</view>
      </view>
      <view class="glossary-summary">{{glossaryPopup.summary}}</view>
      <view class="glossary-reminder">{{glossaryPopup.reminder}}</view>
    </view>
  </view>
</view>
