<view class="page with-tab home-page">
  <view class="hero" style="padding-top: {{heroPaddingTop}}rpx;">
    <image class="hero-photo" src="/assets/hero/village-hero.png" mode="aspectFill" />
    <view class="hero-scrim"></view>
    <view class="hero-copy">
      <view class="hero-title">养娃新手村</view>
      <view class="hero-subtitle">养娃路上，先来村里问问</view>
    </view>
  </view>

  <view class="search-panel card">
    <view class="tap-card search-card" bindtap="goSearch">
      <view class="search-icon"></view>
      <view class="search-placeholder">来村里问问，例如：宝宝发烧能洗澡吗？</view>
      <view class="home-search-action">搜索</view>
    </view>
  </view>

  <scroll-view class="category-scroll section" scroll-x>
    <view class="category-track">
      <view wx:for="{{categories}}" wx:key="id" class="tap-card chip home-chip cat-{{index}}" bindtap="goCategory" data-id="{{item.id}}">
        <image class="chip-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><image class="section-mark pixel-img" src="{{actionIconPaths.hot}}" mode="aspectFit" /><text>村里大家都在问</text></view>
      <button class="btn-plain section-more" bindtap="goSearch">查看更多 ›</button>
    </view>
    <scroll-view class="hot-scroll" scroll-x>
      <view class="hot-track">
        <view wx:for="{{hotQuestions}}" wx:key="id" class="tap-card hot-card hot-{{index}} card" bindtap="goQuestion" data-id="{{item.id}}">
          <view class="hot-title">{{item.title}}</view>
          <view class="hot-meta">{{item.heatText}}热度</view>
          <view class="tag">{{item.tag}}</view>
          <image class="hot-watermark pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><image class="section-mark pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" /><text>今日村里共识</text></view>
      <button class="btn-plain section-more" bindtap="goToday">查看详情 ›</button>
    </view>
    <view class="tap-card consensus-card card" bindtap="goToday">
      <image class="consensus-icon pixel-img" src="{{actionIconPaths.consensus}}" mode="aspectFit" />
      <view class="consensus-main">
        <view class="consensus-title">{{todayResult.title}}</view>
        <view class="consensus-sub">基于 {{todayResult.sourceCount}} 篇内容 · {{todayResult.expertCount}} 位专家/达人观点达成共识</view>
        <view class="stack-bar">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="stack-seg" style="width: {{item.percentage}}%; background: {{item.color}};"></view>
        </view>
        <view class="legend-row">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="legend-item">
            <view class="dot" style="background: {{item.color}};"></view>
            <text>{{item.title}} {{item.percentage}}%</text>
          </view>
        </view>
      </view>
      <view class="arrow-pill">›</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><image class="section-mark pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" /><text>安全红线</text></view>
      <button class="btn-plain section-more" bindtap="goToday">按今日问题判断 ›</button>
    </view>
    <view class="safety-card card">
      <view class="safety-copy">
        <view class="safety-title">出现这些情况，先别只等共识</view>
        <view class="safety-sub">结合今天的共识问题，优先关注这些风险信号。</view>
      </view>
      <view class="safety-grid">
        <view wx:for="{{safetyWarnings}}" wx:key="*this" class="safety-item">
          <image class="safety-icon pixel-img" src="{{actionIconPaths.warning}}" mode="aspectFit" />
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
