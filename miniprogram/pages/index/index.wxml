<view class="page with-tab home-page">
  <view class="hero">
    <view class="hero-title">育儿共识</view>
    <view class="hero-subtitle">科学育儿 · 安心选择</view>
    <view class="home-illus" aria-hidden="true">
      <view class="sun"></view>
      <view class="leaf one"></view>
      <view class="leaf two"></view>
      <view class="house"></view>
    </view>
  </view>

  <view class="search-panel card">
    <view class="tap-card search-card" bindtap="goSearch">
      <view class="search-icon"></view>
      <view class="search-placeholder">搜索育儿问题，例如：宝宝发烧能洗澡吗？</view>
    </view>
  </view>

  <scroll-view class="category-scroll section" scroll-x>
    <view class="category-track">
      <view wx:for="{{categories}}" wx:key="id" class="tap-card chip home-chip cat-{{index}}" bindtap="goCategory" data-id="{{item.id}}">
        <text class="chip-icon">{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><text class="fire-mark">热</text><text>今日热门问题</text></view>
      <button class="btn-plain section-more" bindtap="goSearch">查看更多 ›</button>
    </view>
    <scroll-view class="hot-scroll" scroll-x>
      <view class="hot-track">
        <view wx:for="{{hotQuestions}}" wx:key="id" class="tap-card hot-card hot-{{index}} card" bindtap="goQuestion" data-id="{{item.id}}">
          <view class="hot-title">{{item.title}}</view>
          <view class="hot-meta">{{item.heatText}}热度</view>
          <view class="tag">{{item.tag}}</view>
          <view class="hot-watermark">{{item.tagIcon}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><text class="shield-mark">权</text><text>权威内容</text></view>
      <button class="btn-plain section-more" bindtap="goAuthority">更多来源 ›</button>
    </view>
    <view class="source-grid">
      <view wx:for="{{authoritySources}}" wx:key="id" class="tap-card source-entry source-{{index}}" bindtap="goAuthority" data-type="{{item.type}}">
        <view class="source-icon">{{item.icon}}</view>
        <view class="source-name">{{item.typeName}}</view>
        <view class="source-desc">{{item.name}}</view>
        <view class="source-count">{{item.trustLabel}} ›</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title"><text class="idea-mark">识</text><text>今日共识</text></view>
      <button class="btn-plain section-more" bindtap="goToday">查看详情 ›</button>
    </view>
    <view class="tap-card consensus-card card" bindtap="goToday">
      <view class="consensus-icon">识</view>
      <view class="consensus-main">
        <view class="consensus-title">宝宝咳嗽有痰，需要立刻去医院吗？</view>
        <view class="consensus-sub">基于 {{todayResult.sourceCount}} 篇内容 · {{todayResult.expertCount}} 位专家/达人观点达成共识</view>
        <view class="stack-bar">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="stack-seg seg-{{index}}" style="width: {{item.percentage}}%;"></view>
        </view>
        <view class="legend-row">
          <view wx:for="{{todayResult.viewpoints}}" wx:key="id" class="legend-item">
            <view class="dot dot-{{index}}"></view>
            <text>{{item.title}} {{item.percentage}}%</text>
          </view>
        </view>
      </view>
      <view class="arrow-pill">›</view>
    </view>
  </view>
</view>
