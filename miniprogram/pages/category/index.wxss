.pixel-img {
  display: block;
}

.category-page {
  padding-top: 26rpx;
}

.category-chip-wrap {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx 12rpx;
  margin-top: 22rpx;
  margin-bottom: 2rpx;
}

.category-chip-wrap .chip {
  width: 100%;
  min-width: 0;
  padding: 0 10rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  font-size: 23rpx;
}

.chip-icon {
  margin-right: 8rpx;
  width: 34rpx;
  height: 34rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
}

.category-empty {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx;
}

.category-empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #f4a340;
  font-size: 26rpx;
  font-weight: 700;
  flex: none;
}

.category-empty-main {
  flex: 1;
  min-width: 0;
}

.category-empty-title {
  color: #2f2a25;
  font-size: 28rpx;
  font-weight: 700;
}

.category-empty-desc {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 23rpx;
  line-height: 1.42;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 54rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 24rpx;
  font-weight: 600;
  flex: none;
}

.question-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  min-height: 164rpx;
  padding: 22rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: left;
}

.question-badge {
  width: 68rpx;
  height: 68rpx;
  border-radius: 12rpx;
  flex: none;
}

.question-main {
  flex: 1;
  min-width: 0;
}

.question-title {
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
}

.question-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 23rpx;
  line-height: 1.45;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #8b8178;
  font-size: 22rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}

.authority-mini {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  width: 100%;
  padding: 22rpx 18rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  gap: 14rpx;
}

.authority-mini-item {
  min-width: 0;
  border-radius: 12rpx;
  padding: 10rpx 4rpx 12rpx;
  text-align: center;
}

.mini-icon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 12rpx;
  border-radius: 14rpx;
}

.mini-title {
  color: #2f2a25;
  font-size: 25rpx;
  font-weight: 700;
}

.mini-desc {
  margin-top: 6rpx;
  color: #8b8178;
  font-size: 22rpx;
}
