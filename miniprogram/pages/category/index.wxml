<view class="page with-tab category-page">
  <view class="category-header card">
    <view class="category-title">分类</view>
    <view class="category-subtitle">按育儿场景快速找到共识</view>
  </view>

  <view class="category-chip-wrap">
    <view wx:for="{{categories}}" wx:key="id" class="tap-card chip {{activeCategory == item.id ? 'active' : ''}}" bindtap="changeCategory" data-id="{{item.id}}">
      <text class="chip-icon">{{item.icon}}</text>{{item.name}}
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">热门问题</view>
      <view class="section-more">{{questions.length}} 个问题</view>
    </view>
    <view class="question-list">
      <view wx:for="{{questions}}" wx:key="id" class="tap-card question-row card" bindtap="goQuestion" data-id="{{item.id}}">
        <view class="question-badge">{{item.tagIcon}}</view>
        <view class="question-main">
          <view class="question-title">{{item.title}}</view>
          <view class="question-summary">{{item.summary}}</view>
          <view class="question-meta"><text class="tag">{{item.tag}}</text><text>{{item.heatText}}热度</text></view>
        </view>
        <view class="row-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">权威内容入口</view>
      <button class="btn-plain section-more" bindtap="goAuthority">更多来源 ›</button>
    </view>
    <view class="authority-mini card">
      <view wx:for="{{authoritySources}}" wx:key="id" class="authority-mini-item">
        <view class="mini-icon">{{item.icon}}</view>
        <view class="mini-title">{{item.typeName}}</view>
        <view class="mini-desc">{{item.trustLabel}}</view>
      </view>
    </view>
  </view>
</view>
