.simple-head {
  padding: 30rpx 8rpx 24rpx;
}

.simple-title {
  color: #2f2a25;
  font-size: 46rpx;
  font-weight: 700;
}

.simple-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 26rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 34rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: #fff4e4;
  color: #f4a340;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-copy {
  width: 100%;
}

.empty-title {
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 28rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-card .primary-button {
  min-width: 220rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
}

.question-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 162rpx;
  padding: 24rpx;
  text-align: left;
}

.question-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 28rpx;
  font-weight: 700;
  flex: none;
}

.question-main {
  flex: 1;
  min-width: 0;
}

.question-title {
  color: #2f2a25;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
}

.question-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.45;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #8b8178;
  font-size: 22rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #f4f1ec;
  color: #9a938b;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}
