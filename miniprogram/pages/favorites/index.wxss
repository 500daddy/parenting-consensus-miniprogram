.pixel-img {
  display: block;
}

.simple-head {
  padding: 30rpx 8rpx 24rpx;
}

.simple-title {
  color: #2f2a25;
  font-size: 46rpx;
  font-weight: 700;
}

.simple-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 26rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 34rpx;
}

.empty-icon {
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 20rpx;
  border-radius: 14rpx;
}

.empty-copy {
  width: 100%;
}

.empty-title {
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 28rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-card .primary-button {
  min-width: 220rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
}

.favorite-swipe {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 18rpx;
}

.delete-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  border-radius: 0 18rpx 18rpx 0;
  background: #f36f5b;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.question-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 162rpx;
  padding: 24rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: left;
  transform: translateX(0);
  transition: transform 180ms ease-out;
  position: relative;
  z-index: 1;
}

.question-row.swiped {
  transform: translateX(-176rpx);
}

.question-badge {
  width: 66rpx;
  height: 66rpx;
  border-radius: 12rpx;
  flex: none;
}

.question-main {
  flex: 1;
  min-width: 0;
}

.question-title {
  color: #2f2a25;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 700;
}

.question-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 26rpx;
  line-height: 1.45;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #8b8178;
  font-size: 24rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}
