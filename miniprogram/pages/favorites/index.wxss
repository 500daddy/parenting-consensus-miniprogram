.simple-head {
  padding: 30rpx 8rpx 24rpx;
}

.simple-title {
  color: #2f2a25;
  font-size: 46rpx;
  font-weight: 700;
}

.simple-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 26rpx;
}

.empty-card {
  padding: 34rpx;
}

.empty-title {
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 26rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
}

.question-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  padding: 24rpx;
  text-align: left;
}

.question-main {
  flex: 1;
  min-width: 0;
}

.question-title {
  color: #2f2a25;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
}

.question-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.45;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #8b8178;
  font-size: 22rpx;
}

.row-arrow {
  color: #9a938b;
  font-size: 42rpx;
}
