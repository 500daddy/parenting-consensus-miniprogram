<view class="page with-tab favorites-page">
  <view class="simple-head">
    <view class="simple-title">我的收藏</view>
    <view class="simple-sub">常查共识会沉淀在这里</view>
  </view>

  <view wx:if="{{!favorites.length}}" class="empty-card card">
    <image class="empty-icon pixel-img" src="{{actionIconPaths.favorite}}" mode="aspectFit" />
    <view class="empty-copy">
      <view class="empty-title">还没有收藏</view>
      <view class="empty-desc">在问题汇总页点“收藏”，就能把常用育儿共识放到这里。</view>
    </view>
    <button class="btn-plain primary-button" bindtap="goSearch">去搜索问题</button>
  </view>

  <view wx:else class="question-list">
    <view wx:for="{{favorites}}" wx:key="id" class="favorite-swipe">
      <view class="delete-action" bindtap="removeFavorite" data-id="{{item.id}}">取消收藏</view>
      <view
        class="tap-card question-row card {{swipedId === item.id ? 'swiped' : ''}}"
        bindtap="goQuestion"
        bindtouchstart="onTouchStart"
        bindtouchend="onTouchEnd"
        data-id="{{item.id}}"
      >
        <image class="question-badge pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
        <view class="question-main">
          <view class="question-title">{{item.title}}</view>
          <view class="question-summary">{{item.summary}}</view>
          <view class="question-meta"><text class="tag">{{item.tag}}</text><text>{{item.heatText}}热度</text></view>
        </view>
        <view class="row-arrow"></view>
      </view>
    </view>
  </view>
</view>
