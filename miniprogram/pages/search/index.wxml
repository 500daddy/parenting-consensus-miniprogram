<view class="page with-tab search-page">
  <view class="search-top">
    <view class="search-card card">
      <view class="search-icon"></view>
      <input class="search-input" value="{{keyword}}" placeholder="搜索育儿问题，例如：宝宝发烧能洗澡吗？" confirm-type="search" bindinput="onInput" bindconfirm="search" />
      <view wx:if="{{keyword}}" class="clear-btn" bindtap="clearKeyword" aria-label="清空搜索内容">×</view>
    </view>
    <view class="search-submit" bindtap="search">搜索</view>
  </view>

  <view class="category-strip">
    <view class="category-track">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-chip {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="changeCategory"
        data-id="{{item.id}}"
      >
        <image class="category-icon pixel-img" src="{{item.iconPath}}" mode="aspectFit" />
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{history.length}}" class="section">
    <view class="section-head">
      <view class="section-title">搜索历史</view>
      <button class="btn-plain section-more" bindtap="clearHistory">清空</button>
    </view>
    <view class="history-wrap">
      <view wx:for="{{history}}" wx:key="*this" class="tap-card chip" bindtap="searchHistory" data-keyword="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{sectionTitle}}</view>
      <view class="section-more">{{sectionHint}}</view>
    </view>
    <view wx:if="{{suggestions.length}}" class="question-list">
      <view wx:for="{{suggestions}}" wx:key="id" class="tap-card question-row card" bindtap="goQuestion" data-id="{{item.id}}">
        <image class="question-badge pixel-img" src="{{item.tagIconPath}}" mode="aspectFit" />
        <view class="question-content">
          <view class="question-title">{{item.title}}</view>
          <view class="question-summary">{{item.summary}}</view>
          <view class="question-meta">
            <text class="tag">{{item.tag}}</text>
            <text>{{item.heatText}}热度</text>
          </view>
        </view>
        <view class="row-arrow"></view>
      </view>
    </view>
    <view wx:else class="search-empty card">
      <view class="search-empty-icon">问</view>
      <view class="search-empty-main">
        <view class="search-empty-title">暂无相近问题</view>
        <view class="search-empty-desc">可以提交到待补充池。请尽量写成完整问题，例如：宝宝夜里频繁醒怎么办？</view>
        <view wx:if="{{keyword}}" class="missing-submit" bindtap="submitMissingQuestion">提交这个问题</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showBackToTop}}" class="back-top-btn" bindtap="scrollToTop" aria-label="回到顶部">
    <view class="back-top-arrow"></view>
  </view>
</view>
