.pixel-img {
  display: block;
}

.search-top {
  display: flex;
  gap: 14rpx;
  align-items: center;
  padding-top: 24rpx;
}

.search-top .search-card {
  flex: 1;
  min-width: 0;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  box-shadow: 0 6rpx 0 rgba(183, 143, 83, 0.1), 0 12rpx 24rpx rgba(80, 60, 40, 0.05);
}

.search-submit {
  width: 132rpx;
  height: 84rpx;
  border-radius: 14rpx;
  flex: none;
  box-shadow: 0 6rpx 0 rgba(58, 111, 54, 0.18);
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 38rpx;
  flex: none;
}

.history-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.history-wrap .chip {
  min-height: 58rpx;
  border-color: #deebd8;
  background: #f5fbf1;
  color: #5f8c4a;
  font-size: 24rpx;
  font-weight: 600;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.question-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 170rpx;
  padding: 22rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: left;
}

.question-badge {
  width: 68rpx;
  height: 68rpx;
  border-radius: 12rpx;
  flex: none;
}

.question-content {
  flex: 1;
  min-width: 0;
}

.question-title {
  color: #2f2a25;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
}

.question-summary {
  margin-top: 10rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.45;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 16rpx;
  color: #8b8178;
  font-size: 23rpx;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}

.search-empty {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx;
}

.search-empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #f4a340;
  font-size: 26rpx;
  font-weight: 700;
  flex: none;
}

.search-empty-main {
  flex: 1;
  min-width: 0;
}

.search-empty-title {
  color: #2f2a25;
  font-size: 28rpx;
  font-weight: 700;
}

.search-empty-desc {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 24rpx;
  line-height: 1.45;
}
