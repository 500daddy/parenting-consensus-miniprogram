.profile-page {
  padding-top: 30rpx;
}

.profile-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-top: 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f5fbf1 56%, #fff7eb 100%);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eef6ea;
  border: 8rpx solid rgba(255, 255, 255, 0.82);
  color: #6f985a;
  font-size: 40rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(111, 152, 90, 0.16);
  flex: none;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #2f2a25;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 24rpx;
}

.profile-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.profile-stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid #e7efdf;
}

.stat-num {
  color: #6f985a;
  font-size: 26rpx;
  font-weight: 800;
}

.stat-label {
  color: #8b8178;
  font-size: 22rpx;
}

.baby-card {
  padding: 26rpx;
}

.baby-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.baby-title {
  color: #2f2a25;
  font-size: 30rpx;
  font-weight: 700;
}

.baby-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 23rpx;
}

.baby-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.baby-cell {
  position: relative;
  min-height: 116rpx;
  padding: 18rpx 18rpx 18rpx 70rpx;
  border-radius: 18rpx;
  background: #fffaf3;
  border: 1rpx solid #f1e8dc;
}

.cell-icon {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 18rpx;
  font-weight: 700;
}

.cell-label {
  color: #8b8178;
  font-size: 22rpx;
}

.cell-value {
  margin-top: 10rpx;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
}

.menu-card {
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 98rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f1ece6;
  text-align: left;
}

.menu-row:active {
  background: #f7fbf3;
}

.menu-row.last {
  border-bottom: 0;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-main {
  flex: 1;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 600;
}

.menu-extra {
  color: #8b8178;
  font-size: 24rpx;
  flex: none;
}

.menu-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #f4f1ec;
  color: #8b8178;
  font-size: 34rpx;
  line-height: 1;
  flex: none;
}
