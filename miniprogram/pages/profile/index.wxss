.profile-page {
  padding-top: 30rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f4faef 100%);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 24rpx;
}

.baby-card {
  padding: 24rpx;
}

.baby-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.baby-title {
  color: #2f2a25;
  font-size: 30rpx;
  font-weight: 700;
}

.baby-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 23rpx;
}

.baby-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.baby-cell {
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fffaf3;
}

.cell-label {
  color: #8b8178;
  font-size: 22rpx;
}

.cell-value {
  margin-top: 8rpx;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
}

.menu-card {
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f1ece6;
  text-align: left;
}

.menu-row.last {
  border-bottom: 0;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-main {
  flex: 1;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 600;
}

.menu-extra {
  color: #8b8178;
  font-size: 25rpx;
}
