.pixel-img {
  display: block;
}

.profile-page {
  padding-top: 30rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 0;
  padding: 24rpx;
  border-color: #ead8b8;
  background: linear-gradient(135deg, #fffdf6 0%, #f5fbf1 56%, #fff7eb 100%);
}

.profile-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  width: 100%;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 16rpx;
  background: #eef6ea;
  border: 4rpx solid rgba(255, 255, 255, 0.88);
  color: #6f985a;
  font-size: 40rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(111, 152, 90, 0.16);
  flex: none;
}

.user-avatar {
  background: #fffdf6;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #2f2a25;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.profile-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 24rpx;
  line-height: 1.42;
}

.profile-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  padding-left: 110rpx;
}

.profile-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 0;
  padding-left: 0;
  flex: 1;
  min-width: 0;
}

.profile-stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 253, 246, 0.78);
  border: 2rpx solid #d8e8cf;
  flex: none;
}

.profile-stat:active {
  opacity: 0.82;
  transform: translateY(2rpx);
}

.login-button,
.logout-button,
.edit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-width: 92rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.login-button,
.edit-button {
  border: 2rpx solid #78a764;
  background: #eaf6df;
  color: #376d35;
  box-shadow: 0 4rpx 0 rgba(65, 122, 54, 0.18);
}

.logout-button {
  border: 2rpx solid #efd6ae;
  background: rgba(255, 248, 236, 0.72);
  color: #9d6a32;
  box-shadow: none;
}

.stat-num {
  color: #6f985a;
  font-size: 26rpx;
  font-weight: 800;
}

.stat-label {
  color: #8b8178;
  font-size: 24rpx;
}

.baby-card {
  padding: 24rpx;
  border-color: #ead8b8;
  background: #fffdf6;
}

.baby-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.baby-head-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 14rpx;
  flex: none;
  overflow: hidden;
  box-shadow: 0 4rpx 0 rgba(80, 60, 40, 0.08);
}

.baby-icon-neutral {
  background: #dcefd2;
}

.baby-icon-boy {
  background: #dcecff;
}

.baby-icon-girl {
  background: #ffe2ec;
}

.baby-face {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid #7b5635;
  border-radius: 10rpx;
  background: #ffe7c4;
  box-shadow: inset 0 -4rpx 0 rgba(183, 124, 74, 0.16);
}

.baby-face::before {
  content: "";
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  top: -8rpx;
  height: 12rpx;
  border-radius: 7rpx 7rpx 3rpx 3rpx;
  background: #7b5635;
}

.baby-icon-boy .baby-face::before {
  background: #5b83ba;
}

.baby-icon-girl .baby-face::before {
  background: #cc6f8d;
}

.baby-icon-girl::before,
.baby-icon-girl::after {
  content: "";
  position: absolute;
  top: 9rpx;
  width: 12rpx;
  height: 10rpx;
  border-radius: 5rpx 5rpx 2rpx 5rpx;
  background: #cc6f8d;
}

.baby-icon-girl::before {
  left: 9rpx;
  transform: rotate(-25deg);
}

.baby-icon-girl::after {
  right: 9rpx;
  transform: rotate(25deg);
}

.baby-icon-boy::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 9rpx;
  width: 28rpx;
  height: 7rpx;
  border-radius: 5rpx;
  background: #5b83ba;
}

.baby-eye {
  position: absolute;
  top: 14rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #5c3f2a;
}

.eye-left {
  left: 9rpx;
}

.eye-right {
  right: 9rpx;
}

.baby-mouth {
  position: absolute;
  left: 13rpx;
  bottom: 7rpx;
  width: 8rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #c8795d;
}

.baby-heading {
  flex: 1;
  min-width: 0;
}

.baby-title {
  color: #2f2a25;
  font-size: 30rpx;
  font-weight: 700;
}

.baby-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 23rpx;
}

.baby-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.baby-login-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 20rpx 18rpx;
  border: 2rpx dashed #d8e8cf;
  border-radius: 16rpx;
  background: #f7fbf3;
  position: relative;
}

.baby-login-icon {
  width: 64rpx;
  height: 64rpx;
  flex: none;
  margin-top: 2rpx;
}

.baby-login-main {
  flex: 1;
  min-width: 0;
  padding-right: 112rpx;
}

.baby-login-title {
  color: #2f2a25;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.28;
  max-width: 100%;
}

.baby-login-desc {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 24rpx;
  line-height: 1.48;
}

.login-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: 16rpx;
  top: 18rpx;
  min-width: 82rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #75b86f;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 3rpx 0 rgba(58, 111, 54, 0.16);
}

.baby-cell {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 104rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #fffaf3;
  border: 2rpx solid #f1e8dc;
}

.cell-text {
  flex: 1;
  min-width: 0;
}

.baby-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 78rpx;
  padding: 0 18rpx;
  border: 2rpx solid #f1e8dc;
  border-radius: 14rpx;
  background: #fffaf3;
}

.form-label {
  width: 132rpx;
  color: #8b8178;
  font-size: 24rpx;
  flex: none;
}

.form-input,
.picker-value {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 700;
}

.form-input {
  height: 74rpx;
}

.form-picker-row {
  display: block;
  width: 100%;
}

.picker-row {
  padding-right: 16rpx;
}

.picker-value {
  padding-right: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  width: 14rpx;
  height: 14rpx;
  margin-right: 2rpx;
  border-right: 3rpx solid #9d8c7c;
  border-bottom: 3rpx solid #9d8c7c;
  transform: rotate(45deg);
  flex: none;
}

.form-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
  width: 100%;
  margin-top: 2rpx;
}

.ghost-action,
.save-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 68rpx;
  border-radius: 12rpx;
  font-size: 25rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.ghost-action {
  border: 2rpx solid #ead8b8;
  background: #fffdf6;
  color: #8b8178;
}

.save-action {
  background: #75b86f;
  color: #ffffff;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.18);
}

.cell-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 9rpx;
  background: #eef6ea;
  flex: none;
}

.cell-label {
  color: #8b8178;
  font-size: 24rpx;
}

.cell-value {
  margin-top: 6rpx;
  color: #2f2a25;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-card {
  overflow: hidden;
  border-color: #ead8b8;
  background: #fffdf6;
}

.menu-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 98rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f1ece6;
  text-align: left;
}

.menu-row:active {
  background: #f7fbf3;
}

.menu-row.last {
  border-bottom: 0;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
}

.menu-main {
  flex: 1;
  color: #2f2a25;
  font-size: 27rpx;
  font-weight: 600;
}

.menu-extra {
  color: #8b8178;
  font-size: 24rpx;
  flex: none;
}

.menu-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 34rpx;
  line-height: 1;
  flex: none;
}

.pending-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(47, 42, 37, 0.42);
  box-sizing: border-box;
}

.pending-dialog {
  width: 100%;
  max-width: 650rpx;
  padding: 28rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  box-sizing: border-box;
}

.pending-dialog-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pending-dialog-title {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
}

.pending-dialog-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #fff4e4;
  color: #9d6a32;
  font-size: 34rpx;
  line-height: 1;
  flex: none;
}

.pending-dialog-desc {
  margin-top: 14rpx;
  color: #746b62;
  font-size: 25rpx;
  line-height: 1.48;
}

.pending-question-input {
  width: 100%;
  min-height: 178rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 2rpx solid #ead8b8;
  border-radius: 14rpx;
  background: #fffaf3;
  color: #2f2a25;
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 700;
  box-sizing: border-box;
}

.pending-question-placeholder {
  color: #a59a90;
  font-weight: 500;
}

.pending-dialog-tip {
  margin-top: 12rpx;
  color: #8b8178;
  font-size: 23rpx;
  line-height: 1.4;
}

.pending-dialog-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.pending-cancel,
.pending-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.pending-cancel {
  border: 2rpx solid #ead8b8;
  background: #fffdf6;
  color: #8b8178;
}

.pending-submit {
  background: #75b86f;
  color: #ffffff;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.18);
}
