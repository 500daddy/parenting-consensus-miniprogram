.records-page {
  padding-top: 24rpx;
}

.pixel-img {
  display: block;
}

.records-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.records-head-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 14rpx;
  background: #f7fbf2;
  flex: none;
}

.records-head-copy {
  flex: 1;
  min-width: 0;
}

.records-title {
  color: #2f2a25;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
}

.records-sub {
  margin-top: 6rpx;
  color: #6f6258;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
}

.head-new-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 56rpx;
  border: 2rpx solid #66a65f;
  border-radius: 16rpx;
  background: #75b86f;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 56rpx;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.16);
  flex: none;
}

.records-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
  padding: 38rpx 28rpx 30rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: center;
}

.records-empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  background: #f7fbf2;
}

.records-empty-copy {
  width: 100%;
  margin-top: 18rpx;
}

.records-empty-title {
  color: #2f2a25;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 900;
}

.records-empty-desc {
  width: 520rpx;
  max-width: 100%;
  margin: 12rpx auto 0;
  color: #6f6258;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-actions {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-top: 26rpx;
}

.empty-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  max-width: 100%;
  height: 68rpx;
  border-radius: 14rpx;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.empty-primary {
  border: 2rpx solid #66a65f;
  background: #75b86f;
  color: #ffffff;
  box-shadow: 0 4rpx 0 rgba(58, 111, 54, 0.16);
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.record-card {
  padding: 24rpx;
  border-color: #ead8b8;
  background: #fffdf6;
}

.record-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #f7fbf2;
  flex: none;
}

.record-head-main {
  flex: 1;
  min-width: 0;
}

.record-title {
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.34;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  margin-top: 4rpx;
  color: #8b8178;
  font-size: 22rpx;
  font-weight: 700;
}

.record-meta,
.record-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.record-meta text,
.record-summary text {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #f5fbf1;
  color: #5f8c4a;
  font-size: 21rpx;
  font-weight: 700;
}

.record-summary text {
  background: #fff4e4;
  color: #9d6a32;
}

.record-detail {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #fffaf3;
}

.record-detail-label {
  width: 88rpx;
  color: #9d6a32;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 900;
  flex: none;
}

.record-detail-text {
  flex: 1;
  min-width: 0;
  color: #5e554d;
  font-size: 24rpx;
  line-height: 1.45;
}

.record-questions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #f7fbf2;
}

.record-question {
  color: #42513c;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 700;
}

.record-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.edit-button,
.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border: 2rpx solid #f1b59c;
  border-radius: 999rpx;
  background: #fff1ea;
  color: #b44d39;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.edit-button {
  border-color: #cfe3c4;
  background: #f7fbf2;
  color: #4f8a43;
}
