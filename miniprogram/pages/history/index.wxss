.simple-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 8rpx 24rpx;
}

.simple-title {
  color: #2f2a25;
  font-size: 46rpx;
  font-weight: 700;
}

.simple-sub {
  margin-top: 8rpx;
  color: #8b8178;
  font-size: 26rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 34rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-bottom: 20rpx;
  border-radius: 14rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-copy {
  width: 100%;
}

.empty-title {
  color: #2f2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 28rpx;
  color: #8b8178;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-card .primary-button {
  min-width: 220rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  min-height: 104rpx;
  padding: 0 24rpx;
  border-color: #ead8b8;
  background: #fffdf6;
  text-align: left;
}

.history-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #eef6ea;
  color: #6f985a;
  font-size: 22rpx;
  font-weight: 700;
}

.history-keyword {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 29rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: #fff4e4;
  color: #c17442;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}
