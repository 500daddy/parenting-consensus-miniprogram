.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 12rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.98);
  border-top: 0;
  box-shadow: 0 -18rpx 34rpx rgba(92, 65, 36, 0.07);
}

.tab-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 94rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 82rpx;
  border-radius: 16rpx;
  color: #7a6a55;
  border: 2rpx solid transparent;
}

.tab-item.active {
  background: #eaf6df;
  border-color: #77a85f;
  color: #376d35;
  box-shadow: 0 4rpx 0 rgba(119, 168, 95, 0.18);
}

.tab-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
}

.tab-item.active .tab-icon-wrap {
  background: rgba(255, 253, 246, 0.8);
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
}

.tab-text {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 500;
}

.tab-item.active .tab-text {
  font-weight: 800;
}

.tab-item:active {
  opacity: 0.86;
}
