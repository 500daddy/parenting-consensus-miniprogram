.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 12rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.98);
  border-top: 0;
  box-shadow: 0 -18rpx 34rpx rgba(92, 65, 36, 0.07);
}

.tab-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 94rpx;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 82rpx;
  border-radius: 16rpx;
  color: #7a6a55;
  border: 2rpx solid transparent;
  transform: translateY(0);
  transition: transform 90ms steps(2, end), background-color 120ms steps(2, end), border-color 120ms steps(2, end);
}

.tab-item.active {
  background: #eaf6df;
  border-color: #77a85f;
  color: #376d35;
  box-shadow: 0 5rpx 0 rgba(65, 122, 54, 0.2);
}

.tab-item.pressed {
  transform: translateY(4rpx);
  box-shadow: 0 1rpx 0 rgba(65, 122, 54, 0.18);
}

.tab-icon-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  transform: translateY(0);
}

.tab-item.active .tab-icon-wrap {
  background: rgba(255, 253, 246, 0.8);
  animation: icon-hop 220ms steps(3, end);
}

.tab-item.pressed .tab-icon-wrap {
  animation: icon-press 160ms steps(2, end);
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  position: relative;
  z-index: 1;
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.tab-item.active .tab-text {
  font-weight: 800;
}

.tab-item:active {
  opacity: 0.86;
}

@keyframes icon-hop {
  0% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-8rpx);
  }
  70% {
    transform: translateY(2rpx);
  }
  100% {
    transform: translateY(0);
  }
}

@keyframes icon-press {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(4rpx);
  }
}
