.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 12rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 253, 246, 0.98);
  border-top: 0;
  box-shadow: 0 -18rpx 34rpx rgba(92, 65, 36, 0.07);
}

.tab-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 92rpx;
  border-radius: 16rpx;
  color: #7a6a55;
  border: 2rpx solid transparent;
  transform: translateY(0);
  transition: transform 90ms steps(2, end), background-color 120ms steps(2, end), border-color 120ms steps(2, end);
}

.tab-item.active {
  background: transparent;
  border-color: #77a85f;
  color: #376d35;
  box-shadow: none;
}

.tab-icon-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  transform: translateY(0);
  background: transparent;
}

.tab-item.active .tab-icon-wrap {
  background: transparent;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
}

.tab-text {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 28rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  font-weight: 800;
}

.tab-item:active {
  opacity: 0.72;
}
