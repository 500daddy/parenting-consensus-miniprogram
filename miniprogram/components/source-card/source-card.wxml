<button class="btn-plain source-card card" bindtap="onTap">
  <view class="source-icon">{{source.icon}}</view>
  <view class="source-main">
    <view class="source-title">{{source.name}} <text class="tag">{{source.trustLabel}}</text></view>
    <view class="source-summary">{{source.summary}}</view>
  </view>
  <view class="row-arrow">›</view>
</button>
