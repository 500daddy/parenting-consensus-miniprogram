@import "../../app.wxss";

.source-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  text-align: left;
}

.source-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eef6ea;
  color: #6f985a;
  font-size: 30rpx;
  font-weight: 700;
  flex: none;
}

.source-main {
  flex: 1;
  min-width: 0;
}

.source-head {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.source-title {
  flex: 1;
  min-width: 0;
  color: #2f2a25;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
}

.trust-tag {
  flex: none;
}

.source-summary {
  margin-top: 8rpx;
  color: #756d66;
  font-size: 24rpx;
  line-height: 1.4;
}

.row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #f4f1ec;
  color: #9a938b;
  font-size: 32rpx;
  line-height: 1;
  flex: none;
}
