.tool-card {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-height: 132rpx;
  padding: 14rpx;
  border: 2rpx solid #d8e8cf;
  border-radius: 16rpx;
  background: #f7fbf2;
  box-sizing: border-box;
}

.tool-card:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.tool-icon {
  display: block;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  flex: none;
}

.tool-main {
  flex: 1;
  min-width: 0;
}

.tool-title {
  color: #2f2a25;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 900;
}

.tool-desc {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: #5f6e52;
  font-size: 21rpx;
  line-height: 1.35;
  font-weight: 700;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
