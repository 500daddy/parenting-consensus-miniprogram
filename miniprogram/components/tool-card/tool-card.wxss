.tool-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  min-height: 158rpx;
  padding: 18rpx 16rpx 68rpx;
  border: 2rpx solid #d8e8cf;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fbfff8 0%, #f4fbef 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.78), 0 5rpx 0 rgba(111, 152, 90, 0.08);
  box-sizing: border-box;
  text-align: left;
}

.tool-card:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.tool-icon {
  display: block;
  width: 54rpx;
  height: 54rpx;
  border-radius: 12rpx;
  background: #eaf6df;
  flex: none;
}

.tool-main {
  flex: 1;
  min-width: 0;
}

.tool-head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  min-width: 0;
}

.tool-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #eaf6df;
  color: #4f8a43;
  font-size: 20rpx;
  font-weight: 900;
  flex: none;
}

.tool-title {
  display: -webkit-box;
  color: #2f2a25;
  font-size: 26rpx;
  line-height: 1.28;
  font-weight: 900;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tool-desc {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: #5f6e52;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tool-action {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #4f8a43;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 3rpx 0 rgba(58, 111, 54, 0.18);
  flex: none;
}
