@import "../../app.wxss";

.consensus-card {
  display: block;
  padding: 24rpx;
  text-align: left;
}

.consensus-title {
  color: #2f2a25;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.consensus-sub {
  margin-top: 10rpx;
  color: #8b8178;
  font-size: 23rpx;
  line-height: 1.4;
}

.stack-bar {
  display: flex;
  height: 26rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eee6dc;
}

.stack-seg {
  height: 100%;
}

.seg-0 {
  background: #7ea66a;
}

.seg-1 {
  background: #f4a340;
}

.seg-2 {
  background: #f36f5b;
}
